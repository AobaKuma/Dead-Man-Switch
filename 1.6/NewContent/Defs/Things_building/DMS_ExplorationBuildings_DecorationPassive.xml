<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <DesignatorDropdownGroupDef>
    <defName>DMS_Wreckages</defName>
    <label>Wreckages</label>
  </DesignatorDropdownGroupDef>

  <ThingDef ParentName="DMS_DecorationBuildingBase">
    <defName>DMS_Wreckage_Chunk</defName>
    <label>Wreckage chunk</label>
    <description>一個難以辨認其原本面貌的殘骸塊，嚴格來說是個不錯的掩體，將其徹底拆毀需要一點時間，但能夠回收少量的金屬碎片。</description>
    <graphicData>
      <texPath>Things/Wreckages/DerelictChunk</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <drawSize>(1.2,1.2)</drawSize>
    </graphicData>
    <designatorDropdown>DMS_Wreckages</designatorDropdown>
    <uiIconScale>0.9</uiIconScale>
    <size>(1,1)</size>
    <costList>
      <Steel>50</Steel>
    </costList>
  </ThingDef>

  <ThingDef ParentName="DMS_DecorationBuildingBase">
    <defName>DMS_Wreckage_SentryGun</defName>
    <label>diabled sentry gun</label>
    <description>一座嚴重損毀的小型哨戒砲塔，嚴格來說是個堪用的掩體，能夠回收少量的金屬碎片。</description>
    <graphicData>
      <texPath>Things/Wreckages/DisabledTurret_Small</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <drawSize>(1.1,1.1)</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>150</MaxHitPoints>
      <Mass>20</Mass>
    </statBases>
    <designatorDropdown>DMS_Wreckages</designatorDropdown>
    <uiIconScale>0.9</uiIconScale>
    <size>(1,1)</size>
    <costList>
      <Steel>50</Steel>
    </costList>
  </ThingDef>

  <ThingDef ParentName="DMS_DecorationBuildingBase">
    <defName>DMS_Wreckage_Ronin</defName>
    <label>diabled ronin</label>
    <description>一架嚴重損毀的浪人型機兵，嚴格來說是個堪用的掩體，能夠回收少量的金屬碎片。</description>
    <graphicData>
      <texPath>Things/Wreckages/Disabled_Ronin</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <drawSize>(1.4,1.4)</drawSize>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <Mass>20</Mass>
    </statBases>
    <designatorDropdown>DMS_Wreckages</designatorDropdown>
    <uiIconScale>0.9</uiIconScale>
    <size>(1,1)</size>
    <costList>
      <Steel>50</Steel>
    </costList>
  </ThingDef>
</Defs>