<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationAdd">
				<xpath>Defs/CombatExtended.AmmoInjectorOptions[defName="ammoInjectorOptions"]/benchesByTag/CE_AutoEnableCrafting_TableMachining</xpath>
				<value>
					<li>DMS_TableAmmoPrinter</li>
				</value>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/CombatExtended.AmmoInjectorOptions[defName="ammoInjectorOptions"]/benchesByTag/CE_AutoEnableCrafting_FabricationBench</xpath>
				<value>
					<li>DMS_TableAmmoPrinter</li>
				</value>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
					@Name="SmallAmmoBase"
					]</xpath>
				<value>
					<tradeTags>
						<li>CE_AutoEnableCrafting_DMS_TableAmmoPrinter</li>
					</tradeTags>
				</value>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[
					@Name="AmmoBase" or
					@Name="MediumAmmoBase" or
					@Name="HeavyAmmoBase"
					]/tradeTags</xpath>
				<value>
					<li>CE_AutoEnableCrafting_DMS_TableAmmoPrinter</li>
				</value>
			</li>
			<li Class="PatchOperationAttributeSet">
				<xpath>Defs/ThingDef[defName="Shell_AntigrainWarhead"]/tradeTags</xpath>
				<attribute>Inherit</attribute>
				<value>false</value>
			</li>
			
			<li Class="PatchOperationConditional">
				<xpath>Defs/CombatExtended.AmmoInjectorOptions[defName="ammoInjectorOptions"]/benchesByTag/CE_AutoEnableCrafting</xpath>
				<nomatch Class="PatchOperationAdd">
					<xpath>Defs/CombatExtended.AmmoInjectorOptions[defName="ammoInjectorOptions"]/benchesByTag</xpath>
					<value>
						<CE_AutoEnableCrafting/>
					</value>
				</nomatch>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/CombatExtended.AmmoInjectorOptions[defName="ammoInjectorOptions"]/benchesByTag/CE_AutoEnableCrafting</xpath>
				<value>
					<li>DMS_TableAmmoPrinter</li>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>