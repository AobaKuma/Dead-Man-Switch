<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="ApparelNoQualityBase">
		<defName>DMS_Apparel_PackHound</defName>
		<label>hound drone pack</label>
		<!-- 一種用於攜帶與部署遙控無人機的容器與組裝工具箱，能夠在戰鬥中快速部署一架獵犬無人機並作為遙控控制的基站來控制與回收無人機。 -->
		<description>A container and assembly kit for carrying and deploying remote-controlled  hound drones, capable of quickly deploying a Hound drone in combat and acting as a remote-controlled base station to control and recover the drone.</description>
		<graphicData>
			<texPath>Things/Apparel/DronePack/Icon</texPath>
			<drawSize>1.2</drawSize>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<techLevel>Industrial</techLevel>
		<tradeTags>
			<li>DMS_WeaponRanged</li>
		</tradeTags>
		<statBases>
			<Mass>11</Mass>
			<WorkToMake>40000</WorkToMake>
			<EquipDelay>1</EquipDelay>
			<MarketValue>400</MarketValue>
			<MaxHitPoints>80</MaxHitPoints>
		</statBases>
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<recipeUsers Inherit="False">
				<li>TableMachining</li>
				<li>DMS_TableMachinePrinter</li>
			</recipeUsers>
			<unfinishedThingDef>UnfinishedPack</unfinishedThingDef>
			<researchPrerequisites>
				<li>DMS_UAVBasis</li>
			</researchPrerequisites>
		</recipeMaker>
		<costList>
			<ComponentIndustrial>4</ComponentIndustrial>
			<Steel>60</Steel>
		</costList>
		<tickerType>Never</tickerType>
		<thingCategories>
			<li>ApparelUtility</li>
		</thingCategories>
		<apparel>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<scoreOffset>-4</scoreOffset>
			<careIfWornByCorpse>false</careIfWornByCorpse>
			<careIfDamaged>false</careIfDamaged>
			<ignoredByNonViolent>true</ignoredByNonViolent>
			<wearPerDay>0</wearPerDay>
			<bodyPartGroups>
				<li>Waist</li>
			</bodyPartGroups>
			<layers>
				<li>Belt</li>
			</layers>
			<tags>
				<li>DMS_UAVPack</li>
			</tags>
			<wornGraphicPath>Things/Apparel/DronePack/apparel</wornGraphicPath>
			<wornGraphicData>
				<renderUtilityAsPack>true</renderUtilityAsPack>
				<north>
					<offset>(0,0)</offset>
					<scale>.9</scale>
				</north>
				<south>
					<offset>(0,0.15)</offset>
					<scale>.9</scale>
				</south>
				<east>
					<offset>(-0.35,0.1)</offset>
					<scale>.8</scale>
					<thin>
						<offset>(0.05,0)</offset>
					</thin>
					<hulk>
						<offset>(0,0)</offset>
					</hulk>
					<fat>
						<offset>(0,0)</offset>
					</fat>
					<male>
						<offset>(0,0)</offset>
					</male>
				</east>
				<west>
					<offset>(0.35,0.1)</offset>
					<scale>.8</scale>
					<thin>
						<offset>(-0.05,0)</offset>
					</thin>
					<hulk>
						<offset>(0,0)</offset>
					</hulk>
					<fat>
						<offset>(0,0)</offset>
					</fat>
					<male>
						<offset>(0,0)</offset>
					</male>
				</west>
			</wornGraphicData>
		</apparel>
		<generateCommonality>0.1</generateCommonality>
		<resourceReadoutPriority>Middle</resourceReadoutPriority>
		<smeltable>true</smeltable>
		<burnableByRecipe>false</burnableByRecipe>
		<drawGUIOverlay>false</drawGUIOverlay>
		<verbs>
			<li>
				<commandIcon>UI/Ability/Drone_Send_dog</commandIcon>
				<verbClass>Fortified.Verb_Deploy</verbClass>
				<spawnDef>DMS_Drone_Hound</spawnDef>
				<consumeFuelPerShot>1</consumeFuelPerShot>
				<warmupTime>5.0</warmupTime>
				<hasStandardCommand>true</hasStandardCommand>
				<targetable>false</targetable>
				<onlyManualCast>true</onlyManualCast>
				<useableInVacuum>false</useableInVacuum>
				<soundCast>ThrowGrenade</soundCast>
				<targetParams>
					<canTargetSelf>true</canTargetSelf>
				</targetParams>
			</li>
		</verbs>
		<comps>
			<li Class="CompProperties_AIUSablePack">
				<compClass>Fortified.CompDronePack</compClass>
				<checkInterval>60</checkInterval>
			</li>
			<li Class="CompProperties_ApparelReloadable">
				<maxCharges>1</maxCharges>
				<ammoDef>ComponentIndustrial</ammoDef>
				<baseReloadTicks>2500</baseReloadTicks>
				<ammoCountPerCharge>5</ammoCountPerCharge>
				<hotKey>Misc4</hotKey>
				<chargeNoun>drone</chargeNoun>
				<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
			</li>
		</comps>
	</ThingDef>

