<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef MayRequireAnyOf="Ludeon.RimWorld.Royalty,Ludeon.RimWorld.Anomaly" ParentName="BuildingBase">
    <defName>DMS_PerimeterScanner</defName>
    <label>perimeter scanner</label>
    <description>A scanner capable of detecting invisible creatures. The device raises an alarm when it detects the presence of psychically invisible objects within its radius.</description>
    <tickerType>Normal</tickerType>
    <size>(1,1)</size>
    <graphicData>
      <texPath>Things/Building/DMS_PerimeterScanner</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <drawerType>MapMeshAndRealTime</drawerType>
    <altitudeLayer>Building</altitudeLayer>
    <rotatable>false</rotatable>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.35</fillPercent>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>DMS_Category</designationCategory>
    <uiOrder>500</uiOrder>
    <canOverlapZones>false</canOverlapZones>
    <thingCategories>
      <li>BuildingsMisc</li>
    </thingCategories>
    <minifiedDef>MinifiedThing</minifiedDef>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>6000</WorkToBuild>
      <Flammability>0.7</Flammability>
      <Mass>20</Mass>
    </statBases>
    <costList>
      <Tungsteel>30</Tungsteel>
      <ComponentIndustrial>3</ComponentIndustrial>
      <ComponentStamped>1</ComponentStamped>
    </costList>
    <building>
      <ai_neverTrashThis>true</ai_neverTrashThis>
      <expandHomeArea>false</expandHomeArea>
    </building>
    <researchPrerequisites>
      <li>DMS_UAVBasis</li>
    </researchPrerequisites>
    <placeWorkers>
      <li>Fortified.PlaceWorker_PerimeterScanner</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <comps>
      <li Class="Fortified.CompProperties_PerimeterScanner">
        <glowRadius>4.9</glowRadius>
        <glowColor>(200, 0, 0, 0)</glowColor>
        <range>11</range>
        <effecter>DMS_PerimeterScannerAlert</effecter>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>75</basePowerConsumption>
      </li>
      <li Class="CompProperties_Breakdownable"/>
    </comps>
  </ThingDef>

  <ThingDef MayRequireAnyOf="Ludeon.RimWorld.Royalty,Ludeon.RimWorld.Anomaly" ParentName="BuildingBase">
    <defName>DMS_PerimeterScannerTemp</defName>
    <label>perimeter scanner</label>
    <description>A scanner capable of detecting invisible creatures. The device raises an alarm when it detects the presence of psychically invisible objects within its radius.</description>
    <tickerType>Normal</tickerType>
    <size>(1,1)</size>
    <graphicData>
      <texPath>Things/Building/DMS_PerimeterScannerTemp</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <drawerType>MapMeshAndRealTime</drawerType>
    <altitudeLayer>Building</altitudeLayer>
    <rotatable>false</rotatable>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.25</fillPercent>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <canOverlapZones>false</canOverlapZones>
    <stealable>false</stealable>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>6000</WorkToBuild>
      <Flammability>0.7</Flammability>
      <Mass>20</Mass>
    </statBases>
    <building>
      <ai_neverTrashThis>true</ai_neverTrashThis>
      <claimable>false</claimable>
      <expandHomeArea>false</expandHomeArea>
    </building>
    <costList>
      <ComponentIndustrial>1</ComponentIndustrial>
      <Tungsteel>10</Tungsteel>
    </costList>
    <placeWorkers>
      <li>Fortified.PlaceWorker_PerimeterScanner</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <comps>
      <li Class="Fortified.CompProperties_PerimeterScanner">
        <glowRadius>4.9</glowRadius>
        <glowColor>(200, 0, 0, 0)</glowColor>
        <range>11</range>
        <effecter>DMS_PerimeterScannerAlert</effecter>
      </li>
      <li Class="CompProperties_MechPowerCell">
        <totalPowerTicks>60000</totalPowerTicks>
        <killWhenDepleted>true</killWhenDepleted>
        <labelOverride>Battery power</labelOverride>
        <tooltipOverride>This perimeter scanner has a limited battery life. Once it runs out, it will stop working entirely.</tooltipOverride>
